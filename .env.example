NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Optional API guard. Comma-separated values accepted by x-api-key.
API_KEYS=local-dev-key

# Google AI Studio through Vercel AI SDK. Keep the real key in .env.local only.
AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash
GOOGLE_GENERATIVE_AI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=64

# Authentication. Use strong values in production; never commit real passwords.
AUTH_COOKIE_NAME=asid
AUTH_SESSION_TTL_SECONDS=28800
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@empresa.local
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_TEST_REQUESTER_EMAIL=solicitante.teste@empresa.local
AUTH_TEST_REQUESTER_PASSWORD=

# Ticket storage. Use auto in dev; set redis in production with Upstash/Vercel KV envs.
TICKET_STORAGE=auto
TICKET_REDIS_PREFIX=ai-service-desk
TICKET_SEED_SAMPLE_DATA=false
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative Upstash env names supported by @upstash/redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Qdrant vector store.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=service_desk_knowledge

# Frontend dev server. The app uses same-origin /api by default so HttpOnly auth also works for CopilotKit.
VITE_DEV_API_TARGET=http://localhost:4000
# Optional only when frontend and API are deployed on different origins.
# VITE_API_BASE_URL=
# VITE_COPILOT_RUNTIME_URL=
